{
  "name": "qrawl-mcp",
  "version": "0.1.0",
  "description": "MCP server for qrawl — connect Claude, Cursor, Windsurf, VS Code to live web data",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "qrawl-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev":   "tsup --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@qrawl-dev/types":          "workspace:*",
    "qrawl":                     "workspace:*",
    "qrawl-core":                "workspace:*",
    "zod":                       "^3.23.0"
  },
  "devDependencies": {
    "tsup":       "^8.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "keywords": ["mcp", "qrawl", "web-scraping", "claude", "cursor", "ai-agents"]
}
