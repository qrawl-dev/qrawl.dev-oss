{
  "name": "qrawl",
  "version": "0.1.0",
  "description": "Official SDK for the qrawl.dev cloud API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@qrawl/types": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "keywords": ["qrawl", "web-crawler", "scraper", "ai-agents", "cloud"]
}
