{
  "name": "qrawl",
  "version": "0.1.0-alpha.0",
  "description": "Official SDK for the qrawl.dev cloud API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@qrawl-dev/types": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "qrawl",
    "web-crawler",
    "scraper",
    "ai-agents",
    "cloud"
  ],
  "author": "Abdul Qayyum",
  "homepage": "https://qrawl.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qrawl-dev/qrawl.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/qrawl-dev/qrawl/issues"
  },
  "files": [
    "dist"
  ]
}
