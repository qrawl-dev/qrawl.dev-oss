{
  "name": "@qrawl-dev/types",
  "version": "0.1.0-alpha.0",
  "description": "Shared TypeScript types for qrawl packages",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "Abdul Qayyum",
  "homepage": "https://qrawl.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qrawl-dev/qrawl.git",
    "directory": "packages/types"
  },
  "bugs": {
    "url": "https://github.com/qrawl-dev/qrawl/issues"
  },
  "files": [
    "dist"
  ]
}
