{
  "name": "qrawl-core",
  "version": "0.1.0-alpha.0",
  "description": "Self-hostable BFS web crawler engine — powers qrawl.dev",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@qrawl-dev/types": "workspace:*",
    "node-html-parser": "^6.1.13",
    "turndown": "^7.2.0",
    "robots-parser": "^3.0.1",
    "p-queue": "^8.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.5",
    "@types/uuid": "^9.0.8",
    "vitest": "^1.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "web-crawler",
    "scraper",
    "ai",
    "agents",
    "markdown"
  ],
  "author": "Abdul Qayyum",
  "homepage": "https://qrawl.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qrawl-dev/qrawl.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/qrawl-dev/qrawl/issues"
  },
  "files": [
    "dist"
  ]
}
