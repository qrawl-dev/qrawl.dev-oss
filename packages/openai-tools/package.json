{
  "name": "@qrawl-dev/openai-tools",
  "version": "0.1.0-alpha.0",
  "description": "qrawl tools for OpenAI Agents SDK, Assistants API, and function calling",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "peerDependencies": {
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  },
  "dependencies": {
    "@qrawl-dev/types": "workspace:*",
    "qrawl": "workspace:*"
  },
  "devDependencies": {
    "openai": "^4.50.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "openai",
    "agents",
    "function-calling",
    "qrawl",
    "web-scraping"
  ],
  "author": "Abdul Qayyum",
  "homepage": "https://qrawl.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qrawl-dev/qrawl.git",
    "directory": "packages/openai-tools"
  },
  "bugs": {
    "url": "https://github.com/qrawl-dev/qrawl/issues"
  },
  "files": [
    "dist"
  ]
}
