{
  "name": "qrawl-llamaindex",
  "version": "0.1.0",
  "description": "Official qrawl reader for LlamaIndex.TS — web crawling for RAG",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev":   "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "peerDependencies": {
    "llamaindex": ">=0.3.0"
  },
  "dependencies": {
    "@qrawl/types": "workspace:*",
    "qrawl": "workspace:*"
  },
  "devDependencies": {
    "llamaindex": "^0.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "keywords": ["llamaindex", "qrawl", "reader", "rag", "web-scraping"]
}
