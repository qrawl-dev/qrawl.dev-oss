{
  "name": "@qrawl-dev/langchain",
  "version": "0.1.0-alpha.0",
  "description": "Official qrawl document loader for LangChain — web crawling for RAG pipelines",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2.0",
    "langchain": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "langchain": {
      "optional": true
    }
  },
  "dependencies": {
    "@qrawl-dev/types": "workspace:*",
    "qrawl": "workspace:*"
  },
  "devDependencies": {
    "@langchain/core": "^0.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "langchain",
    "qrawl",
    "loader",
    "rag",
    "document-loader",
    "web-scraping"
  ],
  "author": "Abdul Qayyum",
  "homepage": "https://qrawl.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qrawl-dev/qrawl.git",
    "directory": "packages/langchain"
  },
  "bugs": {
    "url": "https://github.com/qrawl-dev/qrawl/issues"
  },
  "files": [
    "dist"
  ]
}
